NORTHSTAR_DATABASE_PATH=./data/northstar.sqlite3
# Production uses PostgreSQL instead of NORTHSTAR_DATABASE_PATH.
DATABASE_URL=postgresql://user:password@host:5432/northstar
NORTHSTAR_DEMO_PASSWORD=Demo123!
NORTHSTAR_DEMO_DATE=2026-07-12
# Production reset operations require a separate owner-controlled secret (24+ characters).
NORTHSTAR_OPERATOR_RESET_TOKEN=replace-with-a-long-random-operator-token
NORTHSTAR_DEMO_RESET_COOLDOWN_SECONDS=300
